# =============================================================================
# Local development (supabase start). These values are the defaults the local
# Supabase stack prints. Copy this file to .env and replace ANTHROPIC_API_KEY.
# =============================================================================

# Local Supabase (defaults from `supabase start`).
SUPABASE_URL=http://127.0.0.1:54321
# EXTERNAL_SUPABASE_URL is the URL the *client* uses to reach Supabase. The
# edge runtime overrides SUPABASE_URL with the internal Kong hostname; this
# env var is what we use to rewrite signed URLs so they're reachable from outside.
EXTERNAL_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Anthropic Managed Agents.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_WEBHOOK_SIGNING_KEY=whsec_...
ANTHROPIC_BETA_HEADER=managed-agents-2026-04-01

# Optional. Default model for agent creation.
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7
